# typed: true
# frozen_string_literal: true

class Colophon < Formula
  desc "Generate back-of-book indexes and glossaries from Markdown or Typst."
  homepage "__HOMEPAGE__"
  version "__VERSION__"
  license "Apache-2.0 OR MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "__RELEASE_URL__/colophon-#{version}-aarch64-apple-darwin.tar.gz"
      sha256 "__SHA_DARWIN_ARM64__"
    else
      url "__RELEASE_URL__/colophon-#{version}-x86_64-apple-darwin.tar.gz"
      sha256 "__SHA_DARWIN_X64__"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "__RELEASE_URL__/colophon-#{version}-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_ARM64__"
    else
      url "__RELEASE_URL__/colophon-#{version}-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_X64__"
    end
  end

  def install
    bin.install "bin/colophon"
    man1.install Dir["share/man/man1/*.1"]
    bash_completion.install "share/completions/colophon.bash" => "colophon"
    zsh_completion.install "share/completions/_colophon"
    fish_completion.install "share/completions/colophon.fish"
  end

  test do
    assert_match version.to_s, shell_output("\#{bin}/colophon --version-only")
  end
end
